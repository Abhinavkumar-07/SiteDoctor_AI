# ── Supabase (public — safe to expose, RLS enforces access) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google Analytics ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Cloud (server-only — never expose to the client bundle) ────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
CLOUD_TASKS_QUEUE_NAME=sitedoctor-audit-queue
CLOUD_TASKS_LOCATION=us-central1

# URL of the worker Cloud Run service — Cloud Tasks delivers audit jobs here.
# Set to http://localhost:3001 in local dev if running the worker locally.
WORKER_SERVICE_URL=https://worker-xxxxxxxx-uc.a.run.app

# ── Rate limiting (tunable without a code change) ─────────────────────────────
# Max audit submissions per IP per window.
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Local dev only ────────────────────────────────────────────────────────────
# Not needed in production (Cloud Run provides these automatically).
# NODE_ENV=development
